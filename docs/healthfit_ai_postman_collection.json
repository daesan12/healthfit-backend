              "mode": "raw",
              "raw": "{\n  \"scope\": \"meal\",\n  \"message\": \"맵지 않은 한식 고단백 저녁 식단을 추천해줘.\",\n  \"target_date\": \"{{target_date}}\",\n  \"food_source\": \"all\",\n  \"meal_order\": 1,\n  \"meal_label\": \"저녁\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/v1/ai/diet/recommendations/",
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"공통 응답 형식을 반환한다\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"success\");",
                  "    pm.expect(json).to.have.property(\"message\");",
                  "});",
                  "if (pm.response.code < 400) {",
                  "    const data = pm.response.json().data;",
                  "    pm.collectionVariables.set(\"diet_recommendation_id\", data.recommendation_id);",
                  "    const meal = data.meals && data.meals[0];",
                  "    const item = meal && meal.items && meal.items[0];",
                  "    if (meal) pm.collectionVariables.set(\"meal_order\", meal.meal_order);",
                  "    if (item && item.food_id) pm.collectionVariables.set(\"replace_food_id\", item.food_id);",
                  "}"
                ]
              }
            }
          ]
        },
