{
  "name": "HealthFit Backend API",
  "version": "2026-06-21-current-backend",
  "status": "current backend contract",
  "base_url": "http://127.0.0.1:8000/api/v1",
  "canonical_human_document": "api명세서.txt",
  "endpoint_count": 69,
  "planned_endpoint_count": 6,
  "planned_notice": "프론트 연동 시에는 Implemented APIs 섹션만 우선 사용한다. Planned / Not Implemented Yet APIs는 이후 구현 예정이며, 현재 백엔드에서는 호출하면 404가 발생할 수 있다.",
  "authentication": {
    "type": "JWT Bearer",
    "header": "Authorization: Bearer {access_token}",
    "access_token_storage_key_used_by_frontend": "healthfit_access_token"
  },
  "common_response": {
    "success": {
      "success": true,
      "message": "요청별 성공 메시지",
      "data": "endpoint별 data"
    },
    "error": {
      "success": false,
      "message": "요청별 실패 메시지",
      "errors": {
        "field": ["오류 메시지"]
      }
    }
  },
  "frontend_notes": [
    "Axios 원본 응답에서는 response.data.data를 사용한다.",
    "frontend/src/api/client.js의 unwrapResponse()를 거친 함수는 내부 data를 직접 반환한다.",
    "운동 endpoint는 /exercises/이며 /workouts/는 존재하지 않는다.",
    "식단 대시보드는 /meals/dashboard/이다.",
    "RoutineItem은 exercise_id, 새 WorkoutLog와 AI progression은 workout_id를 사용하며 모두 숫자 Exercise DB PK이다. WorkoutLog의 기존 exercise_id도 호환된다.",
    "Exercise 응답의 문자열 exercise_id는 외부 ExerciseDB 또는 custom 식별자이다.",
    "Post 목록 data는 {count,page,page_size,results} 객체이다.",
    "diet 게시글은 작성자 본인의 shared_saved_meal_id, workout 게시글은 작성자 본인의 shared_workout_routine_id를 선택적으로 첨부할 수 있다.",
    "Post의 공유 대상은 snapshot으로 응답되며 원본 수정/삭제 후에도 유지된다. 인증 사용자는 save-shared-meal 또는 save-shared-routine으로 자신의 계정에 복사할 수 있다.",
    "오류 응답은 Axios의 error.response.data에서 읽는다.",
    "AI API는 JWT 인증과 backend/.env의 GMS_KEY가 필요하다.",
    "GMS endpoint는 SSAFY GMS 프록시 https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com/v1beta를 사용한다.",
    "food_source는 all, my_fridge, free이며 free 추천도 FoodSnapshot을 통해 저장할 수 있다.",
    "exercise_source는 all 또는 my_exercises이다.",
    "프론트 연동 시에는 Implemented APIs 섹션만 우선 사용한다. Planned / Not Implemented Yet APIs는 이후 구현 예정이며, 현재 백엔드에서는 호출하면 404가 발생할 수 있다."
  ],
  "schemas": {
    "User": ["id", "username", "email"],
    "Profile": ["id", "gender", "age", "height", "weight", "body_type", "activity_level", "workout_goal", "workout_experience"],
    "BodyRecord": ["id", "record_date", "weight", "body_fat_percentage", "skeletal_muscle_mass", "bmi", "created_at"],
    "Food": ["id", "name", "category", "calories", "carbohydrate", "protein", "fat", "user_id"],
    "MealItem": ["id", "food_id", "food_name", "ai_food_key", "amount", "calories", "carbohydrate", "protein", "fat"],
    "Meal": ["id", "meal_type", "meal_order", "meal_label", "intake_date", "total_calories", "total_carbohydrate", "total_protein", "total_fat", "meal_items"],
    "SavedMealItem": ["id", "food_id", "food_name", "ai_food_key", "amount", "calories", "carbohydrate", "protein", "fat"],
    "SavedMeal": ["id", "name", "description", "total_calories", "total_carbohydrate", "total_protein", "total_fat", "saved_meal_items", "created_at", "updated_at"],
    "Exercise": ["id", "exercise_id", "name", "gif_url", "body_parts", "equipments", "target_muscles", "secondary_muscles", "instructions", "user_id", "created_at", "updated_at"],
    "RoutineItem": ["id", "exercise", "order", "sets", "reps", "weight", "rest_seconds"],
    "WorkoutRoutine": ["id", "name", "description", "items", "created_at", "updated_at"],
    "WorkoutLogSet": ["id", "set_order", "weight_kg", "repetition", "duration_seconds", "rpe", "is_warmup", "created_at", "updated_at"],
    "WorkoutLog": ["id", "log_id", "workout_id", "exercise_id", "exercise", "routine_id", "workout_date", "workout_time", "set_count", "repetition", "memo", "sets", "created_at", "updated_at"],
    "Comment": ["id", "post_id", "author", "content", "created_at", "updated_at"],
    "Post": ["id", "author", "title", "content", "category", "shared_type", "shared_saved_meal", "shared_workout_routine", "viewer_save_status", "comment_count", "like_count", "is_liked", "created_at", "updated_at"],
    "SharedSavedMealSnapshot": ["id", "name", "description", "total_calories", "total_carbohydrate", "total_protein", "total_fat", "items"],
    "SharedWorkoutRoutineSnapshot": ["id", "name", "description", "exercise_count", "items"],
    "ViewerSaveStatus": ["saved", "saved_meal_id", "workout_routine_id"],
    "Progress": ["start_date", "end_date", "profile", "body_summary", "meal_summary", "workout_summary"],
    "PublicProfile": ["user", "profile", "post_count", "posts", "representative_saved_meal", "representative_workout_routine"],
    "AIRecommendation": ["recommendation_id", "type", "scope", "food_source", "save_available", "title", "summary", "meals", "daily_target", "daily_totals", "actions"],
    "DietFeedback": ["feedback_id", "date", "score", "total_calories", "total_carbohydrate", "total_protein", "total_fat", "strengths", "improvements", "recommended_actions", "feedback"]
  },
