      "name": "00. 인증",
      "item": [
        {
          "name": "로그인 및 JWT 변수 저장",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login_id\": \"{{login_id}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/api/v1/auth/login/",
            "description": "Collection 변수 login_id와 password를 입력한 뒤 실행합니다."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"공통 응답 형식을 반환한다\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"success\");",
                  "    pm.expect(json).to.have.property(\"message\");",
                  "});",
                  "if (pm.response.code < 400) {",
                  "    const data = pm.response.json().data;",
                  "    pm.collectionVariables.set(\"access_token\", data.access);",
                  "    pm.collectionVariables.set(\"refresh_token\", data.refresh);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
