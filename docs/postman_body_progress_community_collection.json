{
  "info": {
    "name": "Body Progress Community APIs",
    "description": "Body Record, Progress, Post, Comment, Like API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Body Records",
      "item": [
        {
          "name": "신체 기록 목록",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/body-records/?start_date={{start_date}}&end_date={{end_date}}"
          }
        },
        {
          "name": "신체 기록 등록",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"record_date\": \"2026-06-20\",\n  \"weight\": 70.5,\n  \"body_fat_percentage\": 18.2,\n  \"skeletal_muscle_mass\": 32.4\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/body-records/"
          }
        },
        {
          "name": "신체 기록 수정",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight\": 69.8,\n  \"body_fat_percentage\": 17.9\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/body-records/{{body_record_id}}/"
          }
        },
        {
          "name": "신체 기록 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/body-records/{{body_record_id}}/"
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "진행 현황 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/progress/?start_date={{start_date}}&end_date={{end_date}}"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "게시글 목록",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/posts/?page=1"
          }
        },
        {
          "name": "게시글 작성",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"오늘의 운동 기록\",\n  \"content\": \"오늘 전신 운동을 완료했습니다.\",\n  \"category\": \"workout\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/posts/"
          }
        },
        {
          "name": "게시글 상세",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/"
          }
        },
        {
          "name": "게시글 수정",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"수정된 운동 기록\",\n  \"content\": \"운동 기록 내용을 수정했습니다.\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/"
          }
        },
        {
          "name": "게시글 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "댓글 작성",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"좋은 운동 기록입니다!\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/comments/"
          }
        },
        {
          "name": "댓글 수정",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"수정된 댓글입니다.\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{base_url}}/api/v1/comments/{{comment_id}}/"
          }
        },
        {
          "name": "댓글 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/comments/{{comment_id}}/"
          }
        }
      ]
    },
    {
      "name": "Likes",
      "item": [
        {
          "name": "좋아요 토글",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/posts/{{post_id}}/like/"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:8000"},
    {"key": "access_token", "value": ""},
    {"key": "start_date", "value": "2026-06-01"},
    {"key": "end_date", "value": "2026-06-30"},
    {"key": "body_record_id", "value": "1"},
    {"key": "post_id", "value": "1"},
    {"key": "comment_id", "value": "1"}
  ]
}
