{
  "info": {
    "name": "Workout Log APIs",
    "description": "Workout Log 목록, 생성, 상세, 수정, 삭제 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "운동 기록 목록 조회",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/workout-logs/"
      }
    },
    {
      "name": "운동 기록 생성",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"exercise_id\": {{exercise_id}},\n  \"routine_id\": {{routine_id}},\n  \"workout_date\": \"2026-06-20\",\n  \"workout_time\": 30,\n  \"set_count\": 3,\n  \"repetition\": 10,\n  \"memo\": \"무리 없이 완료\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{base_url}}/api/v1/workout-logs/"
      }
    },
    {
      "name": "운동 기록 상세 조회",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/workout-logs/{{log_id}}/"
      }
    },
    {
      "name": "운동 기록 수정",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workout_time\": 40,\n  \"set_count\": 4,\n  \"repetition\": 12,\n  \"memo\": \"수정된 운동 기록\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{base_url}}/api/v1/workout-logs/{{log_id}}/"
      }
    },
    {
      "name": "운동 기록 삭제",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/api/v1/workout-logs/{{log_id}}/"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "exercise_id",
      "value": "1"
    },
    {
      "key": "routine_id",
      "value": "1"
    },
    {
      "key": "log_id",
      "value": "1"
    }
  ]
}
